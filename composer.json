{
    "name": "arjundhi/magento2-payment-method-surcharge",
    "description": "Magento 2 module for configurable payment-method surcharge fees across cart, checkout, order, invoice, credit memo, PDF, and email totals.",
    "type": "magento2-module",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "magento2",
        "payment-fee",
        "payment-surcharge",
        "checkout",
        "sales-totals",
        "rameera"
    ],
    "support": {
        "issues": "https://github.com/arjundhi/magento2-payment-method-surcharge/issues",
        "source": "https://github.com/arjundhi/magento2-payment-method-surcharge"
    },
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3 || ^8.4",
        "magento/framework": "^103.0",
        "magento/module-checkout": "^100.4",
        "magento/module-quote": "^101.2",
        "magento/module-sales": "^103.0",
        "magento/module-tax": "^100.4"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Rameera\\PaymentMethodSurcharge\\": ""
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
